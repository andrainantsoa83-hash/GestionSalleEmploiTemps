@model GestionSalleEmploiTemps.Models.Niveau

@{
    ViewData["Title"] = "Modifier le Niveau";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card-premium">
            <div class="mb-4">
                <a asp-action="Index" class="text-decoration-none text-muted small mb-2 d-inline-block">
                    <i class="fas fa-arrow-left me-1"></i> Retour à la liste
                </a>
                <h4 class="fw-bold">Modifier : @Model.Nom</h4>
                <p class="text-muted small">Mise à jour des informations du niveau académique.</p>
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="Nom" class="form-label small fw-bold">Nom du Niveau</label>
                    <input asp-for="Nom" class="form-control form-control-premium" />
                    <span asp-validation-for="Nom" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label small fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control form-control-premium" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn-premium">
                        <i class="fas fa-save me-2"></i> Enregistrer les modifications
                    </button>
                    <a asp-action="Index" class="btn btn-light border btn-sm">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
