@model IEnumerable<GestionSalleEmploiTemps.Models.Niveau>

@{
    ViewData["Title"] = "Gestion des Niveaux";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold">Niveaux et Filieres</h4>
            <p class="text-muted small">Gerez les filieres Emit de L1 a L3 : Informatique, Management et Multimedia.</p>
        </div>
        <a asp-action="Create" class="btn-premium text-decoration-none">
            <i class="fas fa-plus me-2"></i> Ajouter un Niveau
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="border-0 rounded-start">Nom</th>
                    <th class="border-0">Description</th>
                    <th class="border-0">Salle(s) Attitrée(s)</th>
                    <th class="border-0 text-center rounded-end" style="width: 150px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="fw-bold text-primary">@item.Nom</td>
                        <td>
                            <span class="text-muted small">@(string.IsNullOrEmpty(item.Description) ? "Aucune description" : item.Description)</span>
                        </td>
                        <td>
                            @if (ViewBag.SallesParNiveau != null && ((Dictionary<int, List<string>>)ViewBag.SallesParNiveau).ContainsKey(item.Id))
                            {
                                foreach (var salleNom in ((Dictionary<int, List<string>>)ViewBag.SallesParNiveau)[item.Id])
                                {
                                    <span class="badge bg-info text-white extra-small me-1">@salleNom</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small italic">Aucune salle</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-circle" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-circle" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any()) {
                    <tr>
                        <td colspan="3" class="text-center py-5">
                            <i class="fas fa-layer-group fa-3x text-muted opacity-25 mb-3"></i>
                            <p class="text-muted">Aucun niveau enregistre pour le moment.</p>
                            <a asp-action="Create" class="btn btn-outline-primary btn-sm rounded-pill">Ajouter le premier niveau</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
