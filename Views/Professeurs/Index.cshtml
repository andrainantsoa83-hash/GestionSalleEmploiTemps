@model IEnumerable<GestionSalleEmploiTemps.Models.Professeur>

@{
    ViewData["Title"] = "Gestion des Professeurs";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h4 class="mb-0 fw-bold">Liste des Professeurs</h4>
            <p class="text-muted small">Gérez l'ensemble des enseignants de l'établissement</p>
        </div>
        <div class="d-flex gap-3 align-items-center flex-wrap">
            <form asp-action="Index" method="get" class="d-flex align-items-center gap-2">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control form-control-sm form-control-premium" placeholder="Rechercher par nom..." />
                <button type="submit" class="btn btn-sm btn-premium">
                    <i class="fas fa-search"></i>
                </button>
                @if (!string.IsNullOrEmpty((string)ViewData["CurrentFilter"]))
                {
                    <a asp-action="Index" class="btn btn-sm btn-light border" title="Effacer la recherche">
                        <i class="fas fa-times"></i>
                    </a>
                }
            </form>
            <a asp-action="Create" class="btn-premium">
                <i class="fas fa-plus me-2"></i> Ajouter un Professeur
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th class="border-0">Professeur</th>
                    <th class="border-0">Contact</th>
                    <th class="border-0">Informations Pro.</th>
                    <th class="border-0">Historique (Dernier Cours)</th>
                    <th class="border-0 text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    var lastCourse = (ViewBag.LastCourses as Dictionary<int, dynamic>)?.ContainsKey(item.Id) == true 
                                     ? (ViewBag.LastCourses as Dictionary<int, dynamic>)[item.Id] : null;
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-soft-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: rgba(56, 189, 248, 0.14);">
                                    <span class="text-primary fw-bold">@item.Nom.Substring(0,1)@item.Prenom.Substring(0,1)</span>
                                </div>
                                <div>
                                    <div class="fw-semibold">@item.Nom @item.Prenom</div>
                                    <div class="text-muted extra-small">ID: #@item.Id</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="small"><i class="far fa-envelope text-muted me-2"></i>@item.Email</div>
                            <div class="small mt-1"><i class="fas fa-phone-alt text-muted me-2"></i>@item.Telephone</div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Statut)) {
                                <div class="badge bg-primary-soft text-primary extra-small mb-1">@item.Statut</div>
                            }
                            @if (!string.IsNullOrEmpty(item.Fonction)) {
                                <div class="small text-muted fw-bold">@item.Fonction</div>
                            }
                            @if (!string.IsNullOrEmpty(item.Departement)) {
                                <div class="extra-small text-muted">@item.Departement</div>
                            }
                            @if (!string.IsNullOrEmpty(item.Diplome)) {
                                <div class="extra-small mt-1"><i class="fas fa-graduation-cap text-muted me-1"></i> @item.Diplome</div>
                            }
                        </td>
                        <td>
                            @if (lastCourse != null) {
                                <div class="badge bg-success-soft text-success px-3 py-2 rounded-3 border-0">
                                    <i class="fas fa-history me-1"></i> @lastCourse.Matiere
                                    <div class="extra-small opacity-75 fw-normal mt-1 text-dark">Le @lastCourse.LastDate.ToString("dd/MM/yyyy")</div>
                                </div>
                            } else {
                                <span class="text-muted small">Aucun historique</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border p-2" title="Modifier">
                                    <i class="fas fa-edit text-primary"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light border p-2 text-danger" title="Supprimer">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any()) {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="fas fa-user-friends fa-3x mb-3 opacity-25"></i>
                            <p>Aucun professeur trouvé. Commencez par en ajouter un !</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        var prevDisabled = ViewBag.PageNumber == 1 ? "disabled" : "";
        var nextDisabled = ViewBag.PageNumber == ViewBag.TotalPages ? "disabled" : "";
        
        <div class="d-flex justify-content-between align-items-center mt-4">
            <span class="small text-muted">Page @ViewBag.PageNumber sur @ViewBag.TotalPages</span>
            <div class="btn-group">
                <a asp-action="Index" asp-route-pageNumber="@(ViewBag.PageNumber - 1)" asp-route-searchString="@ViewData["CurrentFilter"]" class="btn btn-sm btn-light border @prevDisabled">
                    <i class="fas fa-chevron-left me-1"></i> Précédent
                </a>
                <a asp-action="Index" asp-route-pageNumber="@(ViewBag.PageNumber + 1)" asp-route-searchString="@ViewData["CurrentFilter"]" class="btn btn-sm btn-light border @nextDisabled">
                    Suivant <i class="fas fa-chevron-right ms-1"></i>
                </a>
            </div>
        </div>
    }
</div>

<style>
    .extra-small { font-size: 0.75rem; }
    .bg-soft-primary { background-color: rgba(56, 189, 248, 0.14); }
</style>
