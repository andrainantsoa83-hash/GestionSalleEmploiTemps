@model GestionSalleEmploiTemps.Models.Professeur

@{
    ViewData["Title"] = "Supprimer le Professeur";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card-premium border-danger">
            <div class="text-center mb-4">
                <div class="bg-danger-soft rounded-circle d-inline-flex p-3 mb-3">
                    <i class="fas fa-exclamation-triangle fa-2x text-danger"></i>
                </div>
                <h4 class="fw-bold">Supprimer ce professeur ?</h4>
                <p class="text-muted">Cette action est irréversible. Toutes les données associées à @Model.Nom @Model.Prenom seront effacées.</p>
            </div>

            <div class="p-3 bg-light rounded-3 mb-4">
                <div class="row">
                    <div class="col-6 small fw-bold">Nom complet:</div>
                    <div class="col-6 small">@Model.Nom @Model.Prenom</div>
                    <div class="col-6 small fw-bold mt-2">Email:</div>
                    <div class="col-6 small mt-2">@Model.Email</div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger py-2 fw-bold">
                        <i class="fas fa-trash-alt me-2"></i> Confirmer la Suppression
                    </button>
                    <a asp-action="Index" class="btn btn-light border btn-sm">Conserver ce profil</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1); }
</style>
