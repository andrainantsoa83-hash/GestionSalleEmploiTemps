@model GestionSalleEmploiTemps.Models.Cours

@{
    ViewData["Title"] = "Modifier le Cours";
}

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="card-premium">
            <div class="mb-4">
                <a asp-action="Index" class="text-decoration-none text-muted small mb-2 d-inline-block">
                    <i class="fas fa-arrow-left me-1"></i> Retour à l'emploi du temps
                </a>
                <h4 class="fw-bold">Modifier la séance</h4>
                <p class="text-muted small">Ajustez les détails de la séance de cours.</p>
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Matiere" class="form-label small fw-bold">Nom de la Matière</label>
                        <input asp-for="Matiere" class="form-control form-control-premium" placeholder="ex: Algorithmique" />
                        <span asp-validation-for="Matiere" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="NiveauId" class="form-label small fw-bold">Niveau Académique</label>
                        <select asp-for="NiveauId" class="form-select form-control-premium" asp-items="ViewBag.NiveauId"></select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="HeureDebut" class="form-label small fw-bold">Heure de Début</label>
                        <input asp-for="HeureDebut" class="form-control form-control-premium" type="datetime-local" />
                        <span asp-validation-for="HeureDebut" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="HeureFin" class="form-label small fw-bold">Heure de Fin</label>
                        <input asp-for="HeureFin" class="form-control form-control-premium" type="datetime-local" />
                        <span asp-validation-for="HeureFin" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SalleId" class="form-label small fw-bold">Salle de Classe</label>
                        <select asp-for="SalleId" class="form-select form-control-premium" asp-items="ViewBag.SalleId"></select>
                        <span asp-validation-for="SalleId" class="text-danger small"></span>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="col-md-6 mb-4">
                            <label asp-for="ProfesseurId" class="form-label small fw-bold">Professeur Responsable</label>
                            <select asp-for="ProfesseurId" class="form-select form-control-premium" asp-items="ViewBag.ProfesseurId"></select>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="ProfesseurId" />
                    }
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn-premium">
                        <i class="fas fa-save me-2"></i> Enregistrer les modifications
                    </button>
                    <a asp-action="Index" class="btn btn-light border btn-sm">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
