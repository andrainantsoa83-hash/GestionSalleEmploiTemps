@model IEnumerable<GestionSalleEmploiTemps.Models.Cours>

@{
    ViewData["Title"] = "Emploi du Temps Interactif";
    var professeurs = ViewBag.Professeurs as Dictionary<int, string> ?? new Dictionary<int, string>();
    var salles = ViewBag.Salles as Dictionary<int, string> ?? new Dictionary<int, string>();
    var roomAvailability = ViewBag.RoomAvailability as Dictionary<string, List<string>> ?? new Dictionary<string, List<string>>();

    string[] jours = { "Lundi", "Mardi", "Mercredi", "Jeudi", "Vendredi" };
    int[] slots = ViewBag.PlanningHours as int[] ?? new[] { 7, 8, 10, 12, 14, 16 };
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h4 class="mb-0 fw-bold">Planning Hebdomadaire</h4>
            <p class="text-muted small mb-0">Cliquez sur un creneau disponible pour reserver un cours dans une salle libre.</p>
        </div>
        <div class="d-flex gap-3 align-items-center flex-wrap">
            <form method="get" asp-action="Index" class="d-flex align-items-center gap-3 flex-wrap">
                <div class="d-flex align-items-center gap-2">
                    <label class="small fw-bold text-muted text-nowrap">NIVEAU :</label>
                    <select name="niveauId" class="form-select form-select-sm form-control-premium" onchange="this.form.submit()">
                        <option value="">Tous</option>
                        @foreach (var niv in ViewBag.Niveaux as List<GestionSalleEmploiTemps.Models.Niveau> ?? new List<GestionSalleEmploiTemps.Models.Niveau>())
                        {
                            <option value="@niv.Id" selected="@(ViewBag.SelectedNiveauId == niv.Id)">@niv.Nom</option>
                        }
                    </select>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted text-nowrap">PROFESSEUR :</label>
                        <select name="profFilterId" class="form-select form-select-sm form-control-premium" onchange="this.form.submit()">
                            <option value="">Tous les professeurs</option>
                            @foreach (var p in professeurs)
                            {
                                <option value="@p.Key" selected="@(ViewBag.SelectedProfFilterId == p.Key)">@p.Value</option>
                            }
                        </select>
                    </div>
                }
            </form>
            <div class="d-flex gap-2">
                <span class="badge bg-success-soft text-success"><i class="fas fa-circle me-1"></i> Disponible</span>
                <span class="badge bg-indigo-soft text-indigo"><i class="fas fa-circle me-1"></i> Reserve</span>
            </div>
        </div>
    </div>

    <div class="alert alert-light border small mb-4">
        Emploi du temps : lundi a vendredi. Les cours longs gardent leur vraie heure de fin, par exemple 14:00 - 18:00.
    </div>

    <div class="table-responsive">
        <table class="table table-bordered timetable-grid">
            <thead>
                <tr class="bg-light">
                    <th style="width: 100px;">Horaire</th>
                    @foreach (var jour in jours)
                    {
                        <th class="text-center">@jour</th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (int slotIndex = 0; slotIndex < slots.Length; slotIndex++)
                {
                    var slot = slots[slotIndex];
                    var slotEnd = slotIndex + 1 < slots.Length ? slots[slotIndex + 1] : slot + 2;
                    var slotStartTime = TimeSpan.FromHours(slot);
                    var slotEndTime = TimeSpan.FromHours(slotEnd);

                    <tr>
                        <td class="time-slot fw-bold">@slot:00 - @slotEnd:00</td>
                        @for (int i = 0; i < jours.Length; i++)
                        {
                            var dayValue = i + 1;
                            var availabilityKey = $"{dayValue}-{slot}";
                            var freeRooms = roomAvailability.ContainsKey(availabilityKey)
                                ? roomAvailability[availabilityKey]
                                : new List<string>();

                            var coursStarting = Model.FirstOrDefault(c =>
                                (int)c.HeureDebut.DayOfWeek == dayValue &&
                                c.HeureDebut.Hour == slot);
                            var coursInProgress = coursStarting ?? Model.FirstOrDefault(c =>
                                (int)c.HeureDebut.DayOfWeek == dayValue &&
                                c.HeureDebut.TimeOfDay < slotEndTime &&
                                c.HeureFin.TimeOfDay > slotStartTime);

                            <td class="p-1">
                                @if (coursInProgress != null)
                                {
                                    <div class="course-card reserved @(coursStarting == null ? "course-continuation" : "")">
                                        <div class="fw-bold extra-small">
                                            @(coursStarting == null ? "Suite : " : "")@coursInProgress.Matiere
                                        </div>
                                        <div class="tiny text-white-50">
                                            <i class="fas fa-clock"></i> @coursInProgress.HeureDebut.ToString("HH:mm") - @coursInProgress.HeureFin.ToString("HH:mm")
                                        </div>
                                        <div class="tiny text-white-50">
                                            <i class="fas fa-user-tie"></i> @(professeurs.ContainsKey(coursInProgress.ProfesseurId) ? professeurs[coursInProgress.ProfesseurId] : "Prof")
                                        </div>
                                        <div class="tiny text-white-50">
                                            <i class="fas fa-map-marker-alt"></i> @(salles.ContainsKey(coursInProgress.SalleId) ? salles[coursInProgress.SalleId] : "Salle")
                                        </div>
                                        <div class="d-flex gap-2 mt-1">
                                            <a asp-action="Edit" asp-route-id="@coursInProgress.Id" class="text-white opacity-50 tiny text-decoration-none">
                                                <i class="fas fa-edit"></i> Editer
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@coursInProgress.Id" class="text-white opacity-50 tiny text-decoration-none">
                                                <i class="fas fa-trash"></i> Annuler
                                            </a>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <a asp-action="Create" asp-route-day="@dayValue" asp-route-hour="@slot" asp-route-endHour="@slotEnd" class="course-card available text-decoration-none">
                                        <i class="fas fa-plus-circle mb-1"></i>
                                        <span class="tiny fw-bold">LIBRE</span>
                                        <div class="tiny opacity-75 mt-1" title="Salles libres : @string.Join(", ", freeRooms)">
                                            <i class="fas fa-door-open"></i> @freeRooms.Count dispo.
                                        </div>
                                    </a>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
