@{
    Layout = null; // No sidebar for login page
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connexion - Emit</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: linear-gradient(135deg, #0f2742 0%, #0369a1 58%, #38bdf8 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.24);
            border-radius: 24px;
            padding: 3rem;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            animation: fadeIn 0.8s ease-out;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .login-title {
            color: white;
            font-weight: 800;
            letter-spacing: -0.025em;
            margin-bottom: 0.5rem;
        }
        .form-label { color: rgba(255, 255, 255, 0.7); font-size: 0.85rem; font-weight: 600; }
        .form-control-dark {
            background: rgba(15, 39, 66, 0.48);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            border-radius: 12px;
            padding: 0.75rem 1rem;
        }
        .form-control-dark:focus {
            background: rgba(15, 39, 66, 0.62);
            border-color: #38bdf8;
            box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.24);
            color: white;
        }
        .btn-login {
            background: linear-gradient(to right, #0284c7, #38bdf8);
            border: none;
            border-radius: 12px;
            padding: 0.875rem;
            font-weight: 700;
            color: white;
            margin-top: 1.5rem;
            transition: all 0.3s;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(2, 132, 199, 0.42);
        }
        .logo-circle {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-circle">
            <i class="fas fa-calendar-alt fa-2x text-primary"></i>
        </div>
        <div class="text-center mb-4">
            <h2 class="login-title">Emit</h2>
            <p class="text-white-50 small">Connectez-vous pour gérer vos cours</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger bg-danger border-0 text-white small rounded-3 py-2 text-center mb-4">
                <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">ADRESSE EMAIL</label>
                <input type="email" name="email" class="form-control form-control-dark" placeholder="Ex: jean.dupont@ecole.fr" required />
            </div>
            <div class="mb-3">
                <label class="form-label">MOT DE PASSE</label>
                <input type="password" name="password" class="form-control form-control-dark" placeholder="••••••••" required />
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-login">Se Connecter <i class="fas fa-arrow-right ms-2"></i></button>
            </div>
        </form>

        <div class="text-center mt-4">
            <p class="small text-white-50">Pas encore de compte ? <a asp-action="Register" class="text-white fw-bold text-decoration-none border-bottom border-white border-2">S'inscrire gratuitement</a></p>
        </div>
    </div>
</body>
</html>
