@model GestionSalleEmploiTemps.Models.Professeur

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connexion - Ecole Management et Innovation de la Technologie </title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: url('/bg_1-C1H54juf.webp') no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 2rem;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.15); /* Plus transparent */
            backdrop-filter: blur(15px); /* Plus de flou */
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 20px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            padding: 2.5rem;
            width: 100%;
            max-width: 450px;
            animation: fadeIn 0.6s ease-out;
            color: #ffffff; /* Texte en blanc pour le contraste */
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .logo-circle {
            width: 100px;
            height: 100px;
            background: rgba(255, 255, 255, 0.9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
            padding: 10px;
            transition: transform 0.3s ease;
        }
        .logo-circle:hover {
            transform: scale(1.05);
        }
        .login-title {
            color: #ffffff;
            font-weight: 700;
            font-size: 1.4rem;
            text-align: center;
            margin-bottom: 2rem;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.5);
        }
        .form-label {
            color: #f8f9fa;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
        }
        .form-control {
            background-color: rgba(255, 255, 255, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.5);
            padding: 0.75rem 1rem;
            border-radius: 8px;
            color: #333;
        }
        .form-control:focus {
            box-shadow: 0 0 10px rgba(52, 152, 219, 0.5);
            border-color: #3498db;
            background-color: #ffffff;
        }
        .btn-primary {
            background: linear-gradient(135deg, #3498db, #2980b9);
            border: none;
            padding: 0.75rem;
            font-weight: 600;
            border-radius: 8px;
            width: 100%;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #2980b9, #2471a3);
            transform: translateY(-1px);
        }
        .text-muted {
            color: #e0e0e0 !important;
        }
        .text-primary {
            color: #63b3ed !important;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-circle">
            <img src="~/images.jpg" alt="Logo EMIT" style="max-width: 100%; max-height: 100%; object-fit: contain; border-radius: 50%;" />
        </div>
        <h2 class="login-title">EMIT Timetable Management</h2>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success text-center" role="alert" style="background: rgba(40, 167, 69, 0.8); color: white; border: none; font-weight: bold;">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger" role="alert" style="background: rgba(220, 53, 69, 0.8); color: white; border: none;">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-4">
                <label class="form-label text-uppercase small fw-bold">Matricule ou Email</label>
                <input name="email" class="form-control" placeholder="Entrez votre matricule ou email" required />
            </div>

            <div class="mb-4">
                <label class="form-label text-uppercase small fw-bold">Mot de passe</label>
                <input name="password" type="password" class="form-control" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn btn-primary mt-2">Se connecter</button>
        </form>

        <div class="text-center mt-4 pt-3 border-top" style="border-color: rgba(255,255,255,0.2) !important;">
            <span class="text-muted small">Pas encore de compte ?</span>
            <a asp-action="Register" class="text-primary small fw-bold text-decoration-none ms-1">S'inscrire</a>
        </div>
    </div>
</body>
</html>
