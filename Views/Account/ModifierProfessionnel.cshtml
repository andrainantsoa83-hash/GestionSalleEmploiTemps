@model GestionSalleEmploiTemps.Models.Professeur

@{
    ViewData["Title"] = "Modifier mes Informations Professionnelles";
}

<div class="container py-4 max-w-700px" style="max-width: 700px; margin: 0 auto;">
    
    <div class="text-center mb-5 border-bottom pb-4">
        <h2 class="fw-bold text-uppercase tracking-wide text-success">INFORMATIONS PROFESSIONNELLES</h2>
    </div>

    <form asp-action="ModifierProfessionnel" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-5">
            <div class="px-3">
                <div class="mb-3">
                    <label asp-for="Diplome" class="form-label fw-bold text-muted">Diplôme</label>
                    <input asp-for="Diplome" class="form-control" placeholder="Ex: Master, Doctorat..." />
                </div>
                
                <div class="mb-3">
                    <label asp-for="TitreAcademique" class="form-label fw-bold text-muted">Titre académique</label>
                    <input asp-for="TitreAcademique" class="form-control" placeholder="Ex: Professeur, Docteur..." />
                </div>
                
                <div class="mb-3">
                    <label asp-for="DomaineSpecialisation" class="form-label fw-bold text-muted">Domaine de spécialisation</label>
                    <input asp-for="DomaineSpecialisation" class="form-control" placeholder="Ex: Génie Logiciel, Réseaux..." />
                </div>
            </div>
        </div>

        <div class="text-center border-top pt-4">
            <div class="d-flex justify-content-center gap-3">
                <a asp-action="Profil" class="btn btn-outline-secondary px-4 py-2 fw-bold">Annuler</a>
                <button type="submit" class="btn btn-success px-5 py-2 fw-bold text-white">Enregistrer</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}