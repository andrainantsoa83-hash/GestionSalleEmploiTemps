@model GestionSalleEmploiTemps.Models.Professeur

@{
    ViewData["Title"] = "Mon Profil Professionnel";
}

<div class="container py-5">
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- EN-TÊTE DU PROFIL -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="bg-primary" style="height: 120px; background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);"></div>
        <div class="card-body px-5 pb-5 position-relative text-center text-md-start d-md-flex align-items-end gap-4" style="margin-top: -60px;">
            <img src="https://ui-avatars.com/api/?name=@(Model.Prenom)+@(Model.Nom)&background=ffffff&color=0d6efd&size=150&bold=true" 
                 alt="Photo de profil" 
                 class="rounded-circle img-thumbnail shadow bg-white" 
                 style="width: 150px; height: 150px; border-width: 4px;">
            
            <div class="mt-3 mt-md-0 pb-2">
                <h2 class="fw-bold mb-1">@Model.Prenom @Model.Nom</h2>
                <p class="text-muted fs-5 mb-0">
                    <i class="fas fa-id-badge me-2"></i> @(!string.IsNullOrEmpty(Model.TitreAcademique) ? Model.TitreAcademique : "Enseignant")
                </p>
            </div>
            <div class="ms-md-auto mt-3 mt-md-0 pb-2">
                 <a href="#" class="btn btn-outline-secondary rounded-pill fw-bold shadow-sm">
                    <i class="fas fa-key me-2"></i> Changer le mot de passe
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- SECTION 1 : INFORMATIONS PERSONNELLES -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-primary mb-0"><i class="fas fa-user-circle me-2"></i> Informations personnelles</h5>
                    <a asp-action="ModifierPersonnel" class="btn btn-sm btn-light text-primary rounded-pill fw-bold">
                        <i class="fas fa-pen"></i> Modifier
                    </a>
                </div>
                <div class="card-body px-4 pb-4">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted fw-bold"><i class="fas fa-signature text-secondary me-2"></i> Nom</span>
                            <span class="text-dark">@Model.Nom</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted fw-bold"><i class="fas fa-signature text-secondary me-2"></i> Prénom</span>
                            <span class="text-dark">@Model.Prenom</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted fw-bold"><i class="fas fa-venus-mars text-secondary me-2"></i> Sexe</span>
                            <span class="text-dark">@(string.IsNullOrEmpty(Model.Sexe) ? "Non renseigné" : Model.Sexe)</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted fw-bold"><i class="fas fa-birthday-cake text-secondary me-2"></i> Date de naissance</span>
                            <span class="text-dark">@(Model.DateNaissance.HasValue ? Model.DateNaissance.Value.ToString("dd/MM/yyyy") : "Non renseigné")</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted fw-bold"><i class="fas fa-phone text-secondary me-2"></i> Téléphone</span>
                            <span class="text-dark">@(string.IsNullOrEmpty(Model.Telephone) ? "Non renseigné" : Model.Telephone)</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted fw-bold"><i class="fas fa-envelope text-secondary me-2"></i> Email</span>
                            <span class="text-dark">@Model.Email</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center border-bottom-0">
                            <span class="text-muted fw-bold"><i class="fas fa-map-marker-alt text-secondary me-2"></i> Adresse</span>
                            <span class="text-dark text-end" style="max-width: 60%;">@(string.IsNullOrEmpty(Model.Adresse) ? "Non renseignée" : Model.Adresse)</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- SECTION 2 : INFORMATIONS PROFESSIONNELLES -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-success mb-0"><i class="fas fa-graduation-cap me-2"></i> Informations professionnelles</h5>
                    <a asp-action="ModifierProfessionnel" class="btn btn-sm btn-light text-success rounded-pill fw-bold">
                        <i class="fas fa-pen"></i> Modifier
                    </a>
                </div>
                <div class="card-body px-4 pb-4">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted fw-bold"><i class="fas fa-certificate text-secondary me-2"></i> Diplôme</span>
                            <span class="text-dark fw-semibold">@(string.IsNullOrEmpty(Model.Diplome) ? "Non renseigné" : Model.Diplome)</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted fw-bold"><i class="fas fa-user-tie text-secondary me-2"></i> Titre académique</span>
                            <span class="text-dark fw-semibold">@(string.IsNullOrEmpty(Model.TitreAcademique) ? "Non renseigné" : Model.TitreAcademique)</span>
                        </li>
                        <li class="list-group-item px-0 py-4 border-bottom-0 text-center">
                            <span class="d-block text-muted fw-bold mb-3"><i class="fas fa-star text-secondary me-2"></i> Domaine de spécialisation</span>
                            @if(!string.IsNullOrEmpty(Model.DomaineSpecialisation)) {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success p-3 rounded-pill fs-6">
                                    @Model.DomaineSpecialisation
                                </span>
                            } else {
                                <span class="text-muted fst-italic">Non renseigné</span>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
