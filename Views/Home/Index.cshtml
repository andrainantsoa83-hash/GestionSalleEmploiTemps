@{
    ViewData["Title"] = "Tableau de Bord";
}

<div class="dashboard-grid">
    <div class="card-premium stat-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div class="stat-label">Professeurs</div>
                <div class="stat-value">@ViewBag.ProfCount</div>
            </div>
            <div class="bg-primary-soft p-3 rounded-circle">
                <i class="fas fa-chalkboard-teacher text-primary"></i>
            </div>
        </div>
        <div class="mt-3 small text-muted">Professeur top : <span class="fw-bold text-dark">@ViewBag.TopProf</span></div>
    </div>

    <div class="card-premium stat-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div class="stat-label">Salles de Classe</div>
                <div class="stat-value">@ViewBag.SalleCount</div>
            </div>
            <div class="bg-success-soft p-3 rounded-circle">
                <i class="fas fa-door-open text-success"></i>
            </div>
        </div>
        <div class="mt-3">
            <div class="d-flex justify-content-between mb-1">
                <span class="extra-small text-muted">Occupation globale</span>
                <span class="extra-small fw-bold">@ViewBag.OccupationRate%</span>
            </div>
            <div class="progress" style="height: 6px;">
                <div class="progress-bar bg-success" role="progressbar" style="width: @ViewBag.OccupationRate%"></div>
            </div>
        </div>
    </div>

    <div class="card-premium stat-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div class="stat-label">Séances Planifiées</div>
                <div class="stat-value">@ViewBag.CoursCount</div>
            </div>
            <div class="bg-indigo-soft p-3 rounded-circle">
                <i class="fas fa-book text-indigo"></i>
            </div>
        </div>
        <a asp-controller="Cours" asp-action="Index" class="small text-decoration-none mt-3">Voir le planning <i class="fas fa-chevron-right ms-1"></i></a>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card-premium">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0 text-primary"><i class="fas fa-magic me-2"></i> Opportunités de Planification Rapide</h5>
                <span class="badge bg-primary-soft text-primary rounded-pill">Assistant IA</span>
            </div>
            
            <div class="row g-3">
                @foreach (var opp in ViewBag.Opportunities as List<GestionSalleEmploiTemps.Controllers.HomeController.PlanningOpportunity>) {
                    <div class="col-md-6">
                        <div class="p-3 rounded-4 border bg-soft-primary h-100" style="background: rgba(56, 189, 248, 0.06);">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge bg-white text-primary border rounded-pill">@opp.Jour</span>
                                <span class="fw-bold text-primary small">@opp.Heure:00 - @(opp.Heure + 2):00</span>
                            </div>
                            <div class="extra-small text-muted mb-2">Salles libres suggérées :</div>
                            <div class="d-flex flex-wrap gap-1 mb-3">
                                @foreach (var s in opp.SallesDisponibles.Take(3)) {
                                    <span class="badge bg-success-soft text-success fw-normal">@s</span>
                                }
                            </div>
                            <a asp-controller="Cours" asp-action="Create" asp-route-day="@((int)opp.Jour)" asp-route-hour="@opp.Heure" class="btn btn-primary btn-sm w-100 rounded-pill fw-bold">Réserver maintenant</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card-premium">
            <h5 class="fw-bold mb-4"><i class="fas fa-clock-rotate-left me-2 text-muted"></i> Activités Récentes</h5>
            <div class="activity-feed">
                @foreach (var act in ViewBag.RecentActivities as List<GestionSalleEmploiTemps.Models.Cours>) {
                    <div class="d-flex gap-3 mb-3 pb-3 border-bottom border-light last-child-border-0">
                        <div class="bg-light rounded-circle px-3 py-2 h-100">
                            <i class="fas fa-calendar-check text-muted small"></i>
                        </div>
                        <div>
                            <div class="fw-bold small">Nouveau cours : @act.Matiere</div>
                            <div class="extra-small text-muted">
                                @(ViewBag.ProfNames.ContainsKey(act.ProfesseurId) ? ViewBag.ProfNames[act.ProfesseurId] : "Prof") 
                                dans la salle <span class="text-primary">@(ViewBag.SalleNames.ContainsKey(act.SalleId) ? ViewBag.SalleNames[act.SalleId] : "Salle")</span>
                            </div>
                        </div>
                    </div>
                }
                @if (!(ViewBag.RecentActivities as List<GestionSalleEmploiTemps.Models.Cours>).Any()) {
                    <div class="text-center py-4 text-muted small">Aucune activité récente.</div>
                }
            </div>
            <a asp-controller="Cours" asp-action="Index" class="btn btn-light w-100 btn-sm rounded-pill mt-2">Voir tout l'historique</a>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary { background-color: rgba(56, 189, 248, 0.12); }
    .last-child-border-0:last-child { border-bottom: 0 !important; margin-bottom: 0 !important; }
</style>

