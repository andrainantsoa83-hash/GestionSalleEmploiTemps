@model GestionSalleEmploiTemps.Models.Salle

@{
    ViewData["Title"] = "Ajouter une Salle";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card-premium">
            <div class="mb-4">
                <a asp-action="Index" class="text-decoration-none text-muted small mb-2 d-inline-block">
                    <i class="fas fa-arrow-left me-1"></i> Retour à la liste
                </a>
                <h4 class="fw-bold">Nouvelle Salle de Classe</h4>
                <p class="text-muted small">Configurez une nouvelle salle pour les cours.</p>
            </div>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                
                <div class="mb-3">
                    <label asp-for="Nom" class="form-label small fw-bold">Nom de la Salle</label>
                    <input asp-for="Nom" class="form-control form-control-premium" placeholder="Ex: Salle A102" />
                    <span asp-validation-for="Nom" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Batiment" class="form-label small fw-bold">Bâtiment</label>
                        <select asp-for="Batiment" class="form-select form-control-premium">
                            <option value="A">Bâtiment A</option>
                            <option value="B">Bâtiment B</option>
                            <option value="C">Bâtiment C</option>
                            <option value="D">Bâtiment D</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="TypeSalle" class="form-label small fw-bold">Type de Salle</label>
                        <select asp-for="TypeSalle" class="form-select form-control-premium">
                            <option value="Salle de classe">Salle de classe</option>
                            <option value="Amphithéâtre">Amphithéâtre</option>
                            <option value="Salle 3D">Salle 3D</option>
                            <option value="Laboratoire">Laboratoire</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="NiveauId" class="form-label small fw-bold">Affectation au Niveau</label>
                    <select asp-for="NiveauId" class="form-select form-control-premium" asp-items="ViewBag.NiveauId">
                        <option value="">-- Salle Générale --</option>
                    </select>
                    <span asp-validation-for="NiveauId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Capacite" class="form-label small fw-bold">Capacité (Nombre de places)</label>
                    <input asp-for="Capacite" class="form-control form-control-premium" type="number" min="1" placeholder="Ex: 30" />
                    <span asp-validation-for="Capacite" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch p-3 border rounded">
                        <input class="form-check-input" type="checkbox" asp-for="EstDisponible" checked>
                        <label class="form-check-label fw-bold small ms-2" asp-for="EstDisponible">Disponible immédiatement</label>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn-premium">
                        <i class="fas fa-save me-2"></i> Créer la Salle
                    </button>
                    <a asp-action="Index" class="btn btn-light border btn-sm">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
